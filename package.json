  "galleryBanner": {
    "color": "#1F1F28",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.70.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "kanagawa",
    "theme",
    "dark",
    "light",
    "colorscheme"
  ],
  "repository": {
