        "path": "./themes/kanagawa-dragon-no-italics-color-theme.json"
      },
      {
        "label": "Kanagawa Lotus",
        "uiTheme": "vs",
        "path": "./themes/kanagawa-lotus-color-theme.json"
      },
      {
        "label": "Kanagawa Lotus (No Italics)",
