  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.comment"
      ],
      "settings": {
        "foreground": "#8a8980"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "variable.language"
      ],
      "settings": {
        "foreground": "#545464"
      }
    },
    {
      "name": "Variable - this/self",
      "scope": [
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#624c83"
      }
    },
    {
      "name": "Parameter",
      "scope": [
        "variable.parameter",
        "meta.parameter",
        "meta.function.parameters variable"
      ],
      "settings": {
        "foreground": "#5d57a3"
      }
    },
    {
      "name": "Member / property / field",
      "scope": [
        "variable.other.member",
        "variable.other.property",
        "variable.other.object.property",
        "meta.object.member",
        "meta.property.object",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#77713f"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "constant.other",
        "support.constant",
        "variable.other.constant"
      ],
      "settings": {
        "foreground": "#cc6d00"
      }
    },
    {
      "name": "Constant - language (true/false/null/undefined)",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined"
      ],
      "settings": {
        "foreground": "#cc6d00",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.hex",
        "constant.numeric.binary"
      ],
      "settings": {
        "foreground": "#b35b79"
      }
    },
    {
      "name": "Character / escape",
      "scope": [
        "constant.character",
        "constant.character.escape",
        "constant.character.string.escape"
      ],
      "settings": {
        "foreground": "#836f4a",
        "fontStyle": "bold"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.single",
        "string.quoted.double",
        "string.quoted.triple",
        "string.template",
        "string.unquoted",
        "string.heredoc"
      ],
      "settings": {
        "foreground": "#6f894e"
      }
    },
    {
      "name": "String regexp",
      "scope": [
        "string.regexp",
        "string.regexp.character-class"
      ],
      "settings": {
        "foreground": "#836f4a"
      }
    },
    {
      "name": "String template punctuation",
      "scope": [
        "punctuation.definition.string",
        "punctuation.definition.string.begin",
        "punctuation.definition.string.end"
      ],
      "settings": {
        "foreground": "#6f894e"
      }
    },
    {
      "name": "String template embedded expression markers",
      "scope": [
        "punctuation.definition.template-expression",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#c84053"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.other",
        "keyword.declaration",
        "storage",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#624c83"
      }
    },
    {
      "name": "Storage type (class/function/var/let/const)",
      "scope": [
        "storage.type",
        "storage.type.class",
        "storage.type.function",
        "storage.type.struct",
        "storage.type.enum",
        "storage.type.interface"
      ],
      "settings": {
        "foreground": "#597b75"
      }
    },
    {
      "name": "Control flow / statement",
      "scope": [
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.exception"
      ],
      "settings": {
        "foreground": "#624c83",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Return / yield / throw",
      "scope": [
        "keyword.control.return",
        "keyword.control.yield",
        "keyword.control.throw"
      ],
      "settings": {
        "foreground": "#c84053"
      }
    },
    {
      "name": "Import / export / from / as",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as",
        "keyword.control.default"
      ],
      "settings": {
        "foreground": "#c84053"
      }
    },
    {
      "name": "Operator (symbolic)",
      "scope": [
        "keyword.operator",
        "keyword.operator.assignment",
        "keyword.operator.arithmetic",
        "keyword.operator.comparison",
        "keyword.operator.logical",
        "keyword.operator.bitwise",
        "keyword.operator.relational",
        "keyword.operator.ternary",
        "keyword.operator.spread",
        "keyword.operator.rest",
        "keyword.operator.optional",
        "keyword.operator.type.annotation"
      ],
      "settings": {
        "foreground": "#836f4a"
      }
    },
    {
      "name": "Operator (word: and/or/not/in/is)",
      "scope": [
        "keyword.operator.word",
        "keyword.operator.new",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#836f4a",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Function definition / call",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "meta.function-call entity.name.function",
        "support.function",
        "support.function.builtin",
        "variable.function"
      ],
      "settings": {
        "foreground": "#4d699b"
      }
    },
    {
      "name": "Method definition",
      "scope": [
        "entity.name.method",
        "meta.method entity.name.function"
      ],
      "settings": {
        "foreground": "#4d699b"
      }
    },
    {
      "name": "Constructor",
      "scope": [
        "entity.name.function.constructor",
        "variable.function.constructor",
        "support.function.constructor",
        "meta.class entity.name.function"
      ],
      "settings": {
        "foreground": "#6693bf"
      }
    },
    {
      "name": "Type / class / interface name",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "entity.name.struct",
        "entity.name.enum",
        "entity.name.trait",
        "entity.name.namespace",
