      ],
      "settings": {
        "foreground": "#597b75"
      }
    },
    {
      "name": "Decorator / annotation",
      "scope": [
        "entity.name.function.decorator",
        "meta.decorator",
        "punctuation.definition.decorator",
        "storage.type.annotation"
      ],
      "settings": {
        "foreground": "#6693bf"
      }
    },
    {
      "name": "Preprocessor / directives",
      "scope": [
        "meta.preprocessor",
        "keyword.control.directive",
        "entity.name.function.preprocessor"
      ],
      "settings": {
        "foreground": "#c84053"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
